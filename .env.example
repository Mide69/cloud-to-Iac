# ── Option 1: explicit access keys ───────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_DEFAULT_REGION=us-east-1

# ── Option 2: AWS CLI named profile ──────────────────────────────────────────
# Pass --profile <name> to the CLI instead of setting keys here.

# ── Option 3: OIDC / web identity (GitHub Actions, EKS IRSA, etc.) ───────────
# boto3 picks these up automatically when present — no code change needed.
# AWS_WEB_IDENTITY_TOKEN_FILE=/var/run/secrets/eks.amazonaws.com/serviceaccount/token
# AWS_ROLE_ARN=arn:aws:iam::123456789012:role/my-role
# AWS_ROLE_SESSION_NAME=cloud-to-iac

# ── Option 4: explicit role assumption (cross-account or OIDC) ───────────────
# Pass --role-arn arn:aws:iam::123456789012:role/my-role to the CLI.

# ── Claude API key — only needed if using the --ai flag ──────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key
